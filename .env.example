# ─── Supabase (wajib) ──────────────────────────────────────────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# ─── TURN (opsional, wajib produksi saat mode mesh) ────────────────────────
VITE_TURN_URL=
VITE_TURN_USERNAME=
VITE_TURN_CREDENTIAL=

# ─── LiveKit SFU (dual-mode, opsional) ─────────────────────────────────────
# KOSONG  → WebRTC mesh via Supabase Realtime (fallback/dev)
# TERISI  → LiveKit SFU aktif (ws://host:7880 atau wss://...)
# Dev lokal (docker): ws://localhost:7880  — jalankan scripts/dev-livekit.sh
VITE_LIVEKIT_URL=

# ─── LiveKit SERVER secrets (HANYA di server / Supabase Edge Function) ──────
# JANGAN taruh di client bundle. Samai dengan livekit/config.yaml keys.
# Dipakai oleh supabase/functions/livekit-token (LIVEKIT_API_KEY / LIVEKIT_API_SECRET).
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret1234567890abcdefghijklmn

# ─── Android signing fingerprint (rilis) ───────────────────────────────────
# SHA-256 keystore release, uppercase colon-separated. Lihat SECURITY.md
VITE_EXPECTED_SIGNING_HASH=
