{
  "name": "nextvwt-ptt-app-prototype",
  "description": "NextVWT PTT (Push-to-Talk) App Prototype - Real-time communication platform",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "clean": "node -e \"const fs=require('fs');['dist','tmp'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true});console.log('Cleaned: '+d);}catch(e){}});\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "test:integration": "vitest run --reporter=verbose",
    "test:e2e:playwright": "playwright test --workers=1",
    "test:e2e:cypress": "cypress run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@lottiefiles/react-lottie-player": "^3.6.0",
