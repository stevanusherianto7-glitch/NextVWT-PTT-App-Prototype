    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "tailwindcss": "4.1.12",
    "terser": "^5.31.0",
    "typescript-eslint": "^8.60.1",
    "vite": "6.3.5",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  },
